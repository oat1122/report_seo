// KeywordReport, KeywordReportHistory, KeywordRecommend

model KeywordReport {
  id           String   @id @default(uuid())
  keyword      String
  position     Int?
  traffic      Int
  kd           KDLevel
  isTopReport  Boolean  @default(false)
  dateRecorded DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  history    KeywordReportHistory[]
  images     KeywordReportImage[]

  @@map("keywordreport")
}

model KeywordReportImage {
  id        String   @id @default(uuid())
  imageUrl  String
  createdAt DateTime @default(now())

  keywordReportId String
  keywordReport   KeywordReport @relation(fields: [keywordReportId], references: [id], onDelete: Cascade)

  @@index([keywordReportId])
  @@map("keywordreportimage")
}

model KeywordReportHistory {
  id           String   @id @default(uuid())
  keyword      String
  position     Int?
  traffic      Int
  kd           KDLevel
  isTopReport  Boolean
  dateRecorded DateTime @default(now())
  isVisible    Boolean  @default(true)

  reportId String
  report   KeywordReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([dateRecorded])

  @@map("keywordreporthistory")
}

model KeywordRecommend {
  id          String   @id @default(uuid())
  keyword     String
  kd          KDLevel?
  isTopReport Boolean  @default(false)
  note        String?  @db.Text
  createdAt   DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])

  @@map("keywordrecommend")
}
