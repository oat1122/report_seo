// BillingDocument, DocumentItem, CompanySettings, DocumentSequence

enum BillingDocumentType {
  BILLING_NOTE
  INVOICE
  RECEIPT
  TAX_INVOICE
}

model CompanySettings {
  id        String   @id @default(uuid())
  name      String
  address   String   @db.Text
  taxId     String
  phone     String?
  email     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companysettings")
}

model BillingDocument {
  id             String              @id @default(uuid())
  documentNumber String              @unique
  type           BillingDocumentType
  pdfUrl         String
  totalAmount    Decimal             @db.Decimal(12, 2)
  items          Json? // [{ description, detail?, quantity, unit, unitPrice }] — null = legacy doc ก่อนมี field นี้
  note           String?             @db.Text
  dueDate        DateTime? // กำหนดชำระ (INVOICE / BILLING_NOTE)
  paidDate       DateTime? // วันที่ชำระ (RECEIPT)
  generatedAt    DateTime            @default(now())

  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerName   String?
  billingCycleId String?
  billingCycle   BillingCycle? @relation(fields: [billingCycleId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([billingCycleId])
  @@index([type, generatedAt])
  @@map("billingdocument")
}

model DocumentSequence {
  id      String @id @default(uuid())
  prefix  String
  year    Int
  lastSeq Int    @default(0)

  @@unique([prefix, year])
  @@map("documentsequence")
}
