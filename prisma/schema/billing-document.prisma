// BillingDocument, DocumentItem, CompanySettings, DocumentSequence

enum BillingDocumentType {
  BILLING_NOTE
  INVOICE
  RECEIPT
  TAX_INVOICE
}

model CompanySettings {
  id        String   @id @default(uuid())
  name      String
  address   String   @db.Text
  taxId     String
  phone     String?
  email     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companysettings")
}

model DocumentTemplate {
  id        String                @id @default(uuid())
  name      String
  scope     DocumentTemplateScope @default(GENERAL)
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  items        DocumentTemplateItem[]
  paymentPlans PaymentPlan[]

  @@index([scope])
  @@map("documenttemplate")
}

model DocumentTemplateItem {
  id          String           @id @default(uuid())
  templateId  String
  template    DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  description String
  quantity    Int              @default(1)
  unit        String           @default("รายการ")
  unitPrice   Decimal          @db.Decimal(10, 2)
  orderIndex  Int              @default(0)

  @@index([templateId])
  @@map("documenttemplateitem")
}

model BillingDocument {
  id             String              @id @default(uuid())
  documentNumber String              @unique
  type           BillingDocumentType
  pdfUrl         String
  totalAmount    Decimal             @db.Decimal(12, 2)
  note           String?             @db.Text
  generatedAt    DateTime            @default(now())

  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerName   String?
  billingCycleId String?
  billingCycle   BillingCycle? @relation(fields: [billingCycleId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([billingCycleId])
  @@index([type, generatedAt])
  @@map("billingdocument")
}

model DocumentSequence {
  id      String @id @default(uuid())
  prefix  String
  year    Int
  lastSeq Int    @default(0)

  @@unique([prefix, year])
  @@map("documentsequence")
}
