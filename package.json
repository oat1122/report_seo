    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "file-type": "^22.0.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
